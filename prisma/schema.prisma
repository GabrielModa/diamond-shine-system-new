model User {
  id              String          @id @default(cuid())
  email           String          @unique
  password        String?
  name            String?
  role            UserRole        @default(viewer)
  status          String          @default("pending")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  supplyRequests  SupplyRequest[]
  feedbackEntries FeedbackEntry[]
  auditLogs       AuditLog[]      @relation("AuditActor")

  @@map("users")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorEmail String
  action     String
  targetType String
  targetId   String?
  metadata   String?
  createdAt  DateTime @default(now())
  actor      User     @relation("AuditActor", fields: [actorEmail], references: [email])

  @@index([actorEmail])
  @@index([createdAt])
  @@map("audit_logs")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  subject   String
  body      String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("email_templates")
}

model SupplyRequest {
  id             String         @id @default(cuid())
  employeeName   String
  clientLocation String
  priority       SupplyPriority
  products       String
  notes          String?
  status         String         @default("Pending")
  submittedBy    String
  emailSentAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [submittedBy], references: [email])

  @@index([status])
  @@index([submittedBy])
  @@index([createdAt])
  @@map("supply_requests")
}

model FeedbackEntry {
  id              String           @id @default(cuid())
  employeeName    String
  clientLocation  String
  cleanliness     Float
  punctuality     Float
  equipment       Float
  clientRelations Float
  overall         Float
  category        String
  comments        String?
  submittedBy     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [submittedBy], references: [email])

  @@index([submittedBy])
  @@index([employeeName])
  @@index([createdAt])
  @@map("feedback_entries")
}

enum UserRole {
  admin
  supervisor
  employee
  viewer
}

enum SupplyPriority {
  urgent
  normal
  low
}


datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}
